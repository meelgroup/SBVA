# Config file for the sbva package.
# Defines the following variables:
#   SBVA_INCLUDE_DIRS  - include directories for sbva
#   SBVA_LIBRARIES     - libraries to link against
#
# Prefer the imported target:  target_link_libraries(myapp PRIVATE sbva)

@PACKAGE_INIT@

set_and_check(SBVA_INCLUDE_DIRS "@PACKAGE_SBVA_INSTALL_INCLUDEDIR@")

include("${CMAKE_CURRENT_LIST_DIR}/sbvaTargets.cmake")

set(SBVA_LIBRARIES sbva)
set(SBVA_STATIC_LIBRARIES sbva)
set(SBVA_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(SBVA_VERSION_MINOR @PROJECT_VERSION_MINOR@)

check_required_components(sbva)
